{
  "name": "steam-followers",
  "private": false,
  "type": "module",
  "version": "1.0.0",
  "description": "Steam Followers component for Quartz 5",
  "license": "MIT",
  "files": ["dist", "package.json"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "preact": "^10.28.2"
  },
  "dependencies": {
    "@quartz-community/types": "github:quartz-community/types"
  },
  "devDependencies": {
    "preact": "^10.28.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "quartz": {
    "name": "steam-followers",
    "displayName": "Steam Followers",
    "category": "component",
    "version": "1.0.0",
    "quartzVersion": ">=5.0.0",
    "components": {
      "SteamFollowers": {
        "displayName": "Steam Followers",
        "defaultPosition": "left",
        "defaultPriority": 15
      }
    }
  }
}
